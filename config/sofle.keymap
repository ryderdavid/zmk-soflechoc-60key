            timeout-ms = <50>;
        };

        tc_gh_hdgold {
            bindings = <&gh_title>;
            key-positions = <36 14 15>;
            layers = <HD_GOLD>;
            timeout-ms = <50>;
        };

        tc_ph_hdgold {
            bindings = <&ph_title>;
            key-positions = <36 16 17>;
            layers = <HD_GOLD>;
            timeout-ms = <50>;
        };

        tc_wh_hdgold {
            bindings = <&wh_title>;
            key-positions = <36 40 41>;
            layers = <HD_GOLD>;
            timeout-ms = <50>;
        };

        // ── H-digraph title case combos: HD Gold (Right Shift + digraph keys)
        tcr_th_hdgold {
            bindings = <&th_title>;
            key-positions = <49 53 41>;
            layers = <HD_GOLD>;
            timeout-ms = <50>;
        };

        tcr_th_hdgold_nd {
            bindings = <&th_title>;
            key-positions = <49 27 28>;
            layers = <HD_GOLD>;
            timeout-ms = <50>;
        };

        tcr_sh_hdgold {
            bindings = <&sh_title>;
            key-positions = <49 26 27>;
            layers = <HD_GOLD>;
            timeout-ms = <50>;
        };

        tcr_ch_hdgold {
            bindings = <&ch_title>;
            key-positions = <49 39 40>;
            layers = <HD_GOLD>;
            timeout-ms = <50>;
        };

        tcr_gh_hdgold {
            bindings = <&gh_title>;
            key-positions = <49 14 15>;
            layers = <HD_GOLD>;
            timeout-ms = <50>;
        };

        tcr_ph_hdgold {
            bindings = <&ph_title>;
