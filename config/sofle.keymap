/*
 * Profile: hd-gold
 * Description: HD Gold on layer 3, Enth+ on layer 1, H-digraph combos
 * Created: 2026-03-31
 * Based on: engrammer quad-layout
 */

/*
 * Quad-Layout — SOFLE 60-key
 *
 * Four alpha layouts with shared functional layers.
 *
 * Layers:
 *   0 = QWERTY base with CAGS HRM
 *   1 = Hands Down Vibranium V toggle overlay (CSNTK home, linger keys)
 *   2 = Hands Down Vibranium P toggle overlay (SCNTK home, linger keys)
 *   3 = Hands Down Gold toggle overlay (T on thumb, H-digraph combos)
 *   4 = Numbers (number grid + numpad, merged)
 *   5 = Nav (arrows, undo/cut/copy/paste)
 *   6 = Adjust (conditional: NAV + NUMBERS — BT, power, toggles)
 *   7 = Fkeys (F1-F12, media, undo/cut/copy/paste, BT, Studio unlock)
 *   8 = Mouse (mouse movement on right OHAE cluster)
 *   9 = Prec (precision mouse — 1/3 speed)
 *
 * Cycle: QWERTY → HD Vib V → HD Vib P → HD Gold → QWERTY (combo: pos 46+47+48+49)
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/keys.h>
#define ZMK_POINTING_DEFAULT_SCRL_VAL 25
#include <dt-bindings/zmk/pointing.h>

#define QWERTY    0
#define HD_VIB_V  1
#define HD_VIB_P  2
#define HD_GOLD   3
#define NUMBERS   4
#define NAV       5
#define ADJUST    6
#define FKEYS     7
#define MOUSE     8
#define PREC      9

// Mouse movement (195% of ZMK default 600 = 1170)
#ifndef KEYMAP_DRAWER
#define MOVE_UP_FAST    ((-1170) & 0xFFFF)
#define MOVE_DOWN_FAST  ((1170) & 0xFFFF)
#define MOVE_LEFT_FAST  (((-1170) & 0xFFFF) << 16)
#define MOVE_RIGHT_FAST (((1170) & 0xFFFF) << 16)

// Precision mouse movement (1/3 of fast speed)
#define MOVE_UP_SLOW    ((-390) & 0xFFFF)
#define MOVE_DOWN_SLOW  ((390) & 0xFFFF)
#define MOVE_LEFT_SLOW  (((-390) & 0xFFFF) << 16)
#define MOVE_RIGHT_SLOW (((390) & 0xFFFF) << 16)
#endif

/ {
    // Activate ADJUST layer by pressing NAV and NUMBERS together
    conditional_layers {
        compatible = "zmk,conditional-layers";

        adjust_layer {
            if-layers = <NAV NUMBERS>;
            then-layer = <ADJUST>;
        };
    };

    combos {
        compatible = "zmk,combos";

        // ── Escape combos ─────────────────────────────────────────
        esc {
            bindings = <&kp ESCAPE>;
            key-positions = <25 41>;
        };

        esc2 {
            bindings = <&kp ESCAPE>;
            key-positions = <0 12>;
        };

        esc3 {
            bindings = <&kp ESCAPE>;
            key-positions = <0 1>;
        };

        // ── Thumb fat-finger protection ───────────────────────────
        thumb_fatfinger {
            bindings = <&kp SPACE>;
            key-positions = <54 55>;
        };

        thumb_fatfinger_left {
            bindings = <&kp SPACE>;
            key-positions = <52 53>;
        };

        thumb_fatfinger_right {
            bindings = <&kp SPACE>;
            key-positions = <56 57>;
        };

        // ── Layout cycle: QWERTY → HD Vib V → HD Vib P → HD Gold → QWERTY
        layout_to_hd_vib_v {
            bindings = <&tog HD_VIB_V>;
            key-positions = <46 47 48 49>;
            layers = <QWERTY>;
        };

        layout_to_hd_vib_p {
            bindings = <&hd_vib_v_to_hd_vib_p>;
            key-positions = <46 47 48 49>;
            layers = <HD_VIB_V>;
        };

        layout_to_hd_gold {
            bindings = <&hd_vib_p_to_hd_gold>;
            key-positions = <46 47 48 49>;
            layers = <HD_VIB_P>;
        };

        layout_to_qwerty {
            bindings = <&tog HD_GOLD>;
            key-positions = <46 47 48 49>;
            layers = <HD_GOLD>;
        };

        // ── Numbers toggle: G+H positions ─────────────────────────
        numbers_toggle {
            bindings = <&tog NUMBERS>;
            key-positions = <29 30>;
        };

        // ── Fat-finger protection: QWERTY ────────────────────────
        fatfinger_del_q {
            bindings = <&kp B>;
            key-positions = <41 42>;
            layers = <QWERTY>;
        };

        fatfinger_bksp_q {
            bindings = <&kp N>;
            key-positions = <44 43>;
            layers = <QWERTY>;
        };

        // ── Fat-finger protection: HD Vibranium V ─────────────────
        fatfinger_del_hd_vib_v {
            bindings = <&kp FSLH>;
            key-positions = <41 42>;
            layers = <HD_VIB_V>;
        };

        fatfinger_bksp_hd_vib_v {
            bindings = <&kp MINUS>;
            key-positions = <44 43>;
            layers = <HD_VIB_V>;
        };

        // ── Fat-finger protection: HD Vibranium ──────────────────
        fatfinger_del_hd_vib {
            bindings = <&kp FSLH>;
            key-positions = <41 42>;
            layers = <HD_VIB_P>;
        };

        fatfinger_bksp_hd_vib {
            bindings = <&kp MINUS>;
            key-positions = <44 43>;
            layers = <HD_VIB_P>;
        };

        // ── Fat-finger protection: HD Gold ───────────────────────
        fatfinger_del_hdgold {
            bindings = <&kp W>;
            key-positions = <41 42>;
            layers = <HD_GOLD>;
        };

        fatfinger_bksp_hdgold {
            bindings = <&kp MINUS>;
            key-positions = <44 43>;
            layers = <HD_GOLD>;
        };

        // ── R fat-finger: HD Vibranium V and P (R+Enter → R) ─────
        r_fatfinger_hd_vib_v {
            bindings = <&kp R>;
            key-positions = <53 54>;
            layers = <HD_VIB_V>;
        };

        r_fatfinger_hd_vib_p {
            bindings = <&kp R>;
            key-positions = <53 54>;
            layers = <HD_VIB_P>;
        };

        // ── T fat-finger: HD Gold (T+Enter → T) ─────────────────
        t_fatfinger_hdgold {
            bindings = <&kp T>;
            key-positions = <53 54>;
            layers = <HD_GOLD>;
        };

        // ── H-digraph combos: HD Vibranium (left hand) ──────────
        th_hd_vib {
            bindings = <&th_lower>;
            key-positions = <28 29>;
            layers = <HD_VIB_P>;
            timeout-ms = <30>;
        };

        sh_hd_vib {
            bindings = <&sh_lower>;
            key-positions = <25 26>;
            layers = <HD_VIB_P>;
            timeout-ms = <30>;
        };

        ch_hd_vib {
