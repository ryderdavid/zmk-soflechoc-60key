            layers = <HD_VIB_P>;
            timeout-ms = <30>;
        };

        gh_hd_vib {
            bindings = <&gh_lower>;
            key-positions = <16 17>;
            layers = <HD_VIB_P>;
            timeout-ms = <30>;
        };

        ph_hd_vib {
            bindings = <&ph_lower>;
            key-positions = <38 39>;
            layers = <HD_VIB_P>;
            timeout-ms = <30>;
        };

        wh_hd_vib {
            bindings = <&wh_lower>;
            key-positions = <14 15>;
            layers = <HD_VIB_P>;
            timeout-ms = <30>;
        };

        // ── H-digraph title case: HD Vibranium (Left Shift)
        tc_th_hd_vib {
            bindings = <&th_title>;
            key-positions = <36 28 29>;
            layers = <HD_VIB_P>;
            timeout-ms = <50>;
        };

        tc_sh_hd_vib {
            bindings = <&sh_title>;
            key-positions = <36 25 26>;
            layers = <HD_VIB_P>;
            timeout-ms = <50>;
