            bindings = <&th_lower>;
            key-positions = <27 28>;
            layers = <HD_GOLD>;
            timeout-ms = <30>;
        };

        sh_hdgold {
            bindings = <&sh_lower>;
            key-positions = <26 27>;
            layers = <HD_GOLD>;
            timeout-ms = <30>;
        };

        ch_hdgold {
            bindings = <&ch_lower>;
            key-positions = <39 40>;
            layers = <HD_GOLD>;
            timeout-ms = <30>;
        };

        ch_hdgold_sd {
            bindings = <&ch_lower>;
            key-positions = <26 28>;
            layers = <HD_GOLD>;
            timeout-ms = <30>;
